# ==========================================================
# LineBet Pro — variables d'environnement
# ==========================================================

# Clé API-Football (https://www.api-football.com/)
# Tier gratuit : 10 requêtes/MINUTE et 100 requêtes/JOUR.
# ⚠️ Dépasser 10 req/min de façon répétée peut faire SUSPENDRE le compte.
#    L'app applique un limiteur (≤9/min) et plafonne les scans à 8 matchs.
# Direct api-sports.io : crée un compte sur https://dashboard.api-football.com/
API_FOOTBALL_KEY=ta_cle_ici

# Optionnel : hôte de l'API (par défaut le endpoint direct api-sports.io).
# Si tu passes par RapidAPI, mets : https://api-football-v1.p.rapidapi.com/v3
# et renseigne le header host correspondant.
API_FOOTBALL_HOST=https://v3.football.api-sports.io
